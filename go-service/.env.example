# Server configuration
PORT=8080
GIN_MODE="debug"

# Database configuration (Use localhost for local dev, postgres for Docker)
DATABASE_URL="postgres://postgres:postgres@localhost:5432/campus_connect?sslmode=disable"

# Security configuration
API_KEY="your-campus-connect-api-key"
WEBHOOK_SECRET="your-webhook-secret-key"

# Rate Limit configuration
RATE_LIMIT_PER_MINUTE=60
